{
  "name": "titulos-coordinadores",
  "version": "0.1.0",
  "description": "Instalador independiente del módulo coordinadores para el sistema de títulos académicos.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "ec.edu.titulos.coordinadores",
    "productName": "Titulos Coordinadores",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../coordinador.html",
      "../revision.html",
      "../css/**",
      "../js/**",
      "../assets/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
